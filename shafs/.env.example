# ──────────────────────────────────────────────────────────────────────────
# OCR PROVIDER — the switch
# ──────────────────────────────────────────────────────────────────────────
# Pick which OCR engine runs. To switch providers later:
#   1) set OCR_PROVIDER below to the new engine's key (e.g. "textract")
#   2) fill that engine's own keys in its section further down
#   3) register the engine once in src/lib/ocr/extractor.factory.ts
# Nothing else changes — the rest of the app only depends on OCR_PROVIDER.
# Registered: mistral (production, fast, structured tables) | tesseract (dev, free, local)
OCR_PROVIDER=mistral

# ── Provider: mistral ───────────────────────────────────────────────────────
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest

# ── Provider: tesseract (free local OCR — reconstructs tables for free) ─────
# No key needed. Tables are rebuilt from word coordinates (see knobs below).
TESSERACT_LANG=eng
# Render upscale before OCR — higher = sharper = better accuracy, slower (2 is good).
TESSERACT_SCALE=2
# Table reconstruction tuning (only touch if tables come out misaligned):
# Drop low-confidence OCR words (0–100).
TESSERACT_MIN_CONFIDENCE=40
# New row when vertical gap > factor × median word height.
TESSERACT_ROW_GAP_FACTOR=0.6
# New column when horizontal gap > factor × median word height.
TESSERACT_COL_GAP_FACTOR=1.2
# Min words in a row / min rows in a block to treat it as a table.
TESSERACT_MIN_COLUMNS=2
TESSERACT_MIN_TABLE_ROWS=2

# ──────────────────────────────────────────────────────────────────────────
# Shared OCR knobs (apply to whichever provider is active)
# ──────────────────────────────────────────────────────────────────────────
# Per-request hard timeout for the OCR call
OCR_TIMEOUT_MS=120000
# Retries on transient failures (network / 429 / 5xx)
OCR_MAX_RETRIES=2
OCR_RETRY_BASE_DELAY_MS=500
# Pull image crops back from OCR (heavier payload — keep off for speed)
OCR_INCLUDE_IMAGES=false

# ──────────────────────────────────────────────────────────────────────────
# Ingestion guardrails (trust-boundary validation)
# ──────────────────────────────────────────────────────────────────────────
# 25 MiB
INGEST_MAX_FILE_BYTES=26214400
INGEST_ALLOWED_MIME=application/pdf

# ──────────────────────────────────────────────────────────────────────────
# Fragility classification (Stage 2)
# ──────────────────────────────────────────────────────────────────────────
# rule = keyword/material ruleset (fast, free). Swappable for an LLM engine later.
CLASSIFIER_PROVIDER=rule
# Path (relative to project root) to the editable fragility ruleset.
FRAGILITY_RULES_PATH=config/fragility-rules.json

# ──────────────────────────────────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
# true = human-readable, false = JSON lines
LOG_PRETTY=true
PERF_ENABLED=true

# ──────────────────────────────────────────────────────────────────────────
# Stage 5 — Routing + Pricing
# ──────────────────────────────────────────────────────────────────────────
# Google Maps Routes API v2 — server-side only, never prefix NEXT_PUBLIC_.
GOOGLE_MAPS_API_KEY=

# Per-request timeout for routing API calls (ms).
MAPS_TIMEOUT_MS=10000
# Surcharge applied per fragile item (£).
FRAGILITY_SURCHARGE_PER_ITEM=5
# Distance multiplier billed to the customer: 1.0 = one-way, 2.0 = full round trip
# (the van drives back to base empty). Scales billed miles only — reported one-way
# distance is unchanged.
ROUTE_RETURN_FACTOR=2

# ──────────────────────────────────────────────────────────────────────────
# Object storage (Cloudflare R2) — archives the source PDF + structured doc
# ──────────────────────────────────────────────────────────────────────────
# OFF by default: the app runs fine without it (uploads are processed in-memory).
# When enabled, each ingest stores raw/<sha256>.pdf and documents/<sha256>.json,
# content-addressed so re-uploads are idempotent. R2 speaks the S3 API; these are
# the S3-compatible credentials from your Cloudflare R2 dashboard. Server-side
# only — never prefix with NEXT_PUBLIC_.
R2_STORAGE_ENABLED=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
